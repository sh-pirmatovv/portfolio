{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@portfolio/ui": ["packages/ui/src/index.ts"],
      "@portfolio/ui/*": ["packages/ui/src/*"],
      "@portfolio/content": ["packages/content/src/index.ts"],
      "@portfolio/content/*": ["packages/content/src/*"],
      "@portfolio/sdk": ["packages/sdk/src/index.ts"],
      "@portfolio/sdk/*": ["packages/sdk/src/*"]
    }
  }
}

